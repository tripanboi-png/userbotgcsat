# ────────────────────────────────────────────────────────────────
#  Telegram Userbot — Environment Configuration
#  Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ── Telegram API ─────────────────────────────────────────────────
# Dapatkan dari https://my.telegram.org/apps
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ── Owner ─────────────────────────────────────────────────────────
# Telegram User ID pemilik bot
# Cara mendapatkan: forward pesan ke @userinfobot
OWNER_ID=123456789

# ── Owner Session String ──────────────────────────────────────────
# String session akun Telegram pemilik
# Cara generate: jalankan python generate_session.py
OWNER_SESSION=

# ── MongoDB Atlas ─────────────────────────────────────────────────
# Connection string dari MongoDB Atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/userbot_db?retryWrites=true&w=majority

# ── Database Name (optional) ──────────────────────────────────────
DB_NAME=userbot_db

# ── Broadcast Settings (optional) ─────────────────────────────────
# Delay antar pesan saat broadcast (detik)
BROADCAST_DELAY=1.5

# FloodWait sleep threshold (detik)
FLOOD_SLEEP_THRESHOLD=60

# ── Log Level (optional) ──────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
